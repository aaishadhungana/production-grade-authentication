# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/auth_system

# ─────────────────────────────────────────────────────────────────────────────
# JWT — Generate strong secrets: openssl rand -hex 64
# ─────────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_strong_random_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace_with_different_strong_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────────────────
# Email (SMTP)
# For dev, use Ethereal: https://ethereal.email/create
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_pass
EMAIL_FROM_NAME=Auth System
EMAIL_FROM=noreply@example.com

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth
# https://console.cloud.google.com → APIs & Services → Credentials
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─────────────────────────────────────────────────────────────────────────────
# GitHub OAuth
# https://github.com/settings/applications/new
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
